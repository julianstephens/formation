# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development               # development | production

# ── Postgres ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://formation:formation@localhost:5432/formation?sslmode=disable

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.formation.local

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o               # any OpenAI-compatible model name

# ── SSE ───────────────────────────────────────────────────────────────────────
TIMER_TICK_SECONDS=2              # how often the server emits timer_tick events

# ── Garage ───────────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=https://s3.example.com
S3_SECRET_KEY=keyId..
S3_ACCCESS_KEY_ID=sk...